{
    "name": "hellpat/watson",
    "description": "PR blast-radius analyser for PHP. Drop-in Composer dev-dep. Reports which routes / commands / jobs / listeners / tests a git diff reaches. One package, both Laravel and Symfony.",
    "type": "library",
    "license": "MIT",
    "keywords": ["pr", "review", "diff", "blast-radius", "ai-review", "code-review", "laravel", "symfony", "artisan", "console"],
    "homepage": "https://github.com/HellPat/watson",
    "authors": [
        { "name": "Patrick Heller", "email": "patrick.heller@khero.com" }
    ],
    "support": {
        "issues": "https://github.com/HellPat/watson/issues",
        "source": "https://github.com/HellPat/watson"
    },
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "symfony/console": "^6.4|^7.0",
        "symfony/process": "^6.4|^7.0"
    },
    "require-dev": {
        "behat/behat": "^3.14",
        "phpunit/phpunit": "^11.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "symfony/framework-bundle": "^6.4|^7.0",
        "symfony/routing": "^6.4|^7.0"
    },
    "suggest": {
        "illuminate/support": "Required when using on Laravel — auto-registers the watson:* Artisan commands.",
        "symfony/framework-bundle": "Required when using on Symfony — register Watson\\Symfony\\WatsonBundle in config/bundles.php."
    },
    "autoload": {
        "psr-4": { "Watson\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": {
            "Watson\\Tests\\": "tests/",
            "Watson\\Tests\\Behat\\": "features/bootstrap/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.3.x-dev"
        },
        "laravel": {
            "providers": [
                "Watson\\Laravel\\WatsonServiceProvider"
            ]
        }
    },
    "scripts": {
        "behat": "behat",
        "test":  "phpunit",
        "ci":    [
            "@test",
            "@behat"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
