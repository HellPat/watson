{
    "name": "hellpat/watson",
    "description": "PR blast-radius analyser for PHP. Standalone dev-only CLI that introspects Symfony / Laravel apps from the outside. Reports which routes / commands / jobs / listeners / tests a git diff reaches.",
    "type": "library",
    "license": "MIT",
    "keywords": ["pr", "review", "diff", "blast-radius", "ai-review", "code-review", "laravel", "symfony", "artisan", "console"],
    "homepage": "https://github.com/HellPat/watson",
    "authors": [
        { "name": "Patrick Heller", "email": "patrick.heller@khero.com" }
    ],
    "support": {
        "issues": "https://github.com/HellPat/watson/issues",
        "source": "https://github.com/HellPat/watson"
    },
    "bin": ["bin/watson"],
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "roave/better-reflection": "^6.0",
        "symfony/console": "^6.4|^7.0|^8.0",
        "symfony/process": "^6.4|^7.0|^8.0"
    },
    "require-dev": {
        "behat/behat": "^3.14",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": { "Watson\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": {
            "Watson\\Tests\\": "tests/",
            "Watson\\Tests\\Behat\\": "features/bootstrap/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.4.x-dev"
        }
    },
    "scripts": {
        "behat": "behat",
        "test":  "phpunit",
        "ci":    [
            "@test",
            "@behat"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
