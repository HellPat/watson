{
    "name": "watson/fixture-symfony-app",
    "description": "Hermetic Symfony 7 app used by Behat scenarios. MicroKernelTrait + a handful of routes / commands so we can verify watson sees what Symfony actually wired up.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "hellpat/watson": "@dev",
        "symfony/console": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/messenger": "^7.0",
        "symfony/runtime": "^7.0",
        "symfony/yaml": "^7.0"
    },
    "repositories": [
        { "type": "path", "url": "../..", "options": { "symlink": true } }
    ],
    "autoload": {
        "psr-4": { "App\\": "src/" }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true,
            "symfony/flex": false
        },
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
