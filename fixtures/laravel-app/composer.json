{
    "name": "watson/fixture-laravel-app",
    "description": "Hermetic Laravel 11 app for Behat scenarios.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "laravel/framework": "^11.0",
        "phpunit/phpunit": "^11.0",
        "watson/laravel": "@dev"
    },
    "repositories": [
        { "type": "path", "url": "../../packages/core",    "options": { "symlink": true } },
        { "type": "path", "url": "../../packages/laravel", "options": { "symlink": true } }
    ],
    "autoload": {
        "psr-4": { "App\\": "app/" }
    },
    "autoload-dev": {
        "psr-4": { "Tests\\": "tests/" }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
