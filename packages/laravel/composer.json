{
    "name": "watson/laravel",
    "description": "PR blast-radius analyser for Laravel. Auto-registers `watson:blastradius` and `watson:list-entrypoints` Artisan commands; reports which routes / commands / jobs / listeners / tests a diff reaches.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "pr", "review", "diff", "blast-radius", "ai-review", "code-review", "artisan"],
    "homepage": "https://github.com/HellPat/watson",
    "authors": [
        { "name": "Patrick Heller", "email": "patrick.heller@khero.com" }
    ],
    "support": {
        "issues": "https://github.com/HellPat/watson/issues",
        "source": "https://github.com/HellPat/watson"
    },
    "require": {
        "php": ">=8.2",
        "watson/core": "^0.2",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": { "Watson\\Laravel\\": "src/" }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.2.x-dev"
        },
        "laravel": {
            "providers": [
                "Watson\\Laravel\\WatsonServiceProvider"
            ]
        }
    }
}
