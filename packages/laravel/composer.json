{
    "name": "watson/laravel",
    "description": "PR blast-radius analyser for Laravel. Auto-registers the `watson:blastradius` and `watson:list-entrypoints` Artisan commands.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "watson/core": "@dev",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": { "Watson\\Laravel\\": "src/" }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Watson\\Laravel\\WatsonServiceProvider"
            ]
        }
    }
}
