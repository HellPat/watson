{
    "name": "watson/fixture-symfony-micro",
    "type": "project",
    "license": "MIT",
    "description": "Fixture Symfony app exercising the entry-point patterns watson detects.",
    "require": {
        "php": ">=8.2",
        "symfony/framework-bundle": "^7.0",
        "symfony/runtime": "^7.0",
        "symfony/console": "^7.0",
        "symfony/messenger": "^7.0",
        "symfony/scheduler": "^7.0"
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    }
}
